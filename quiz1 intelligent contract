# { "Depends": "py-genlayer:latest" }

from genlayer import *
import json

class QuizContract(gl.Contract):
    # Persistent fields must be declared in the class body [4]
    active_quizzes: TreeMap[Address, str]

    def __init__(self):
        # TreeMap is zero-initialized [4]
        pass

    @gl.public.write
    def generate_quiz(self, topic: str, difficulty: str) -> str:
        """
        Generates study material and 10 questions.
        Sanitizes AI output to remove markdown markers before storing.
        """
        prompt = (
            f"You are an educational AI. Create a quiz on the topic: '{topic}' "
            f"at '{difficulty}' difficulty level.\n\n"
            "REQUIREMENTS:\n"
            "1. Generate a comprehensive paragraph of 'study_material'.\n"
            "2. Generate exactly 10 multiple choice questions.\n"
            "OUTPUT FORMAT:\n"
            "Your ONLY output must be a single, unformatted JSON object. "
            "DO NOT use markdown (e.g., ```json). Structure: "
            '{"study_material": "...", "questions": [{"id": 1, "question": "...", '
            '"options": {"A": "...", "B": "...", "C": "...", "D": "..."}, '
            '"correct_option": "A"}]}'
        ) # [5, 6]

        task = f"Generate a JSON quiz object for topic '{topic}' with 10 questions." # [6]
        criteria = "The output must be a valid JSON object with study_material and 10 questions." # [6, 7]

        # THE FIX: Define a sanitization function for the non-deterministic block
        def get_sanitized_quiz() -> str:
            raw_output = gl.nondet.exec_prompt(prompt)
            # Remove "helpful" markdown markers and whitespace [1-3]
            clean_json = raw_output.replace("```json", "").replace("```", "").strip()
            # Round-trip through json.loads/dumps ensures valid formatting for consensus [3]
            return json.dumps(json.loads(clean_json))

        # Use the sanitization function instead of a direct prompt call [7]
        quiz_json: str = gl.eq_principle.prompt_non_comparative(
            get_sanitized_quiz,
            task=task,
            criteria=criteria
        )

        # Store the clean string in the TreeMap [7]
        self.active_quizzes[gl.message.sender_address] = quiz_json
        return quiz_json

    @gl.public.write
    def submit_answers(self, user_answers: list[str]) -> str:
        """
        Takes user answers and compares them against the sanitized stored quiz.
        """
        sender = gl.message.sender_address

        if sender not in self.active_quizzes:
            return "Error: No active quiz found. Please call generate_quiz first." # [8]

        raw_quiz = self.active_quizzes[sender]

        try:
            # This will now succeed because quiz_json was cleaned during generation
            quiz_data = json.loads(raw_quiz) # [8]
        except:
            return "Error: Stored quiz data is corrupted."

        questions = quiz_data.get("questions", [])
        if len(user_answers) != 10:
            return f"Error: Please submit exactly 10 answers. You submitted {len(user_answers)}." # [9]

        score = 0
        results_breakdown = []

        for i, question in enumerate(questions):
            correct_ans = question.get("correct_option", "A")
            user_ans = user_answers[i].upper()

            if user_ans == correct_ans:
                score += 1
                results_breakdown.append(f"Q{i+1}: Correct")
            else:
                results_breakdown.append(f"Q{i+1}: Wrong (Your: {user_ans}, Correct: {correct_ans})") # [9]

        final_report = {
            "total_score": f"{score}/10",
            "percentage": f"{(score/10)*100}%",
            "details": results_breakdown
        }

        # Clean up storage [10]
        del self.active_quizzes[sender]
        return json.dumps(final_report)