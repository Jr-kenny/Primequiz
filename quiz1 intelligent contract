from genlayer import *
import json


class QuizContract(gl.Contract):
    active_quizzes: TreeMap[Address, str]

    def __init__(self):
        pass

    @gl.public.write
    def generate_quiz(self, topic: str, difficulty: str) -> str:
        prompt = (
            f"You are an educational AI. Create a quiz on the topic '{topic}' "
            f"at '{difficulty}' difficulty level.\n\n"
            "Return only a JSON object with these keys:\n"
            '- "study_material": a comprehensive study paragraph\n'
            '- "questions": exactly 10 multiple choice questions\n'
            "Each question must have:\n"
            '- "id": integer\n'
            '- "question": string\n'
            '- "options": object with keys "A", "B", "C", "D"\n'
            '- "correct_option": one of "A", "B", "C", "D"\n'
            "Do not use markdown or extra text."
        )

        def leader_fn():
            result = gl.nondet.exec_prompt(prompt, response_format="json")
            if not isinstance(result, dict):
                raise gl.UserError("LLM did not return a JSON object")
            return result

        def validator_fn(leader_result) -> bool:
            if not isinstance(leader_result, gl.vm.Return):
                return False

            data = leader_result.calldata
            if not isinstance(data, dict):
                return False

            study_material = data.get("study_material")
            questions = data.get("questions")

            if not isinstance(study_material, str) or len(study_material.strip()) == 0:
                return False

            if not isinstance(questions, list) or len(questions) != 10:
                return False

            for index, question in enumerate(questions, start=1):
                if not isinstance(question, dict):
                    return False

                if not isinstance(question.get("id"), int):
                    return False

                if not isinstance(question.get("question"), str) or len(question["question"].strip()) == 0:
                    return False

                options = question.get("options")
                if not isinstance(options, dict):
                    return False

                for key in ("A", "B", "C", "D"):
                    if not isinstance(options.get(key), str) or len(options[key].strip()) == 0:
                        return False

                if question.get("correct_option") not in ("A", "B", "C", "D"):
                    return False

            return True

        quiz_data = gl.vm.run_nondet_unsafe(leader_fn, validator_fn)
        quiz_json = json.dumps(quiz_data, sort_keys=True)

        self.active_quizzes[gl.message.sender_address] = quiz_json
        return quiz_json

    @gl.public.write
    def submit_answers(self, user_answers: list[str]) -> str:
        sender = gl.message.sender_address

        if sender not in self.active_quizzes:
            return "Error: No active quiz found. Please call generate_quiz first."

        raw_quiz = self.active_quizzes[sender]

        try:
            quiz_data = json.loads(raw_quiz)
        except Exception:
            return "Error: Stored quiz data is corrupted."

        questions = quiz_data.get("questions", [])
        if len(user_answers) != 10:
            return f"Error: Please submit exactly 10 answers. You submitted {len(user_answers)}."

        score = 0
        results_breakdown = []

        for i, question in enumerate(questions):
            correct_ans = question.get("correct_option", "A")
            user_ans = user_answers[i].upper()

            if user_ans == correct_ans:
                score += 1
                results_breakdown.append(f"Q{i+1}: Correct")
            else:
                results_breakdown.append(
                    f"Q{i+1}: Wrong (Your: {user_ans}, Correct: {correct_ans})"
                )

        final_report = {
            "total_score": f"{score}/10",
            "percentage": f"{(score / 10) * 100}%",
            "details": results_breakdown,
        }

        del self.active_quizzes[sender]
        return json.dumps(final_report, sort_keys=True)
