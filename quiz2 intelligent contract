from genlayer import *
import json


class QuizGenerator(gl.Contract):
    quiz_count: u256
    quizzes: TreeMap[u256, str]

    def __init__(self):
        self.quiz_count = u256(0)

    @gl.public.write
    def generate_quiz(self, material: str, difficulty: str) -> u256:
        def leader_fn():
            prompt = (
                "Analyze the following material and generate a quiz.\n"
                f"Difficulty Level: {difficulty}\n\n"
                f"Material:\n{material}\n\n"
                "Return only a valid JSON object with this structure:\n"
                '{ "summary": "...", "questions": ['
                '{ "question": "...", "options": { "A": "...", "B": "...", "C": "...", "D": "..." }, "answer": "A" }'
                "] }\n"
                "Do not use markdown or extra text."
            )

            result = gl.nondet.exec_prompt(prompt, response_format="json")
            if not isinstance(result, dict):
                raise gl.UserError("LLM did not return a JSON object")
            return result

        def validator_fn(leader_result) -> bool:
            if not isinstance(leader_result, gl.vm.Return):
                return False

            data = leader_result.calldata
            if not isinstance(data, dict):
                return False

            summary = data.get("summary")
            questions = data.get("questions")

            if not isinstance(summary, str) or len(summary.strip()) == 0:
                return False

            if not isinstance(questions, list) or len(questions) == 0:
                return False

            for question in questions:
                if not isinstance(question, dict):
                    return False

                if not isinstance(question.get("question"), str):
                    return False

                options = question.get("options")
                if not isinstance(options, dict):
                    return False

                for key in ("A", "B", "C", "D"):
                    if not isinstance(options.get(key), str):
                        return False

                if question.get("answer") not in ("A", "B", "C", "D"):
                    return False

            return True

        quiz_data = gl.vm.run_nondet_unsafe(leader_fn, validator_fn)
        quiz_json_result = json.dumps(quiz_data, sort_keys=True)

        current_id = self.quiz_count
        self.quizzes[current_id] = quiz_json_result
        self.quiz_count += u256(1)

        return current_id

    @gl.public.view
    def get_quiz(self, quiz_id: u256) -> str:
        if quiz_id >= self.quiz_count:
            raise gl.Rollback("Quiz ID does not exist.")
        return self.quizzes[quiz_id]

    @gl.public.view
    def grade_quiz(self, quiz_id: u256, user_answers: DynArray[str]) -> str:
        quiz_json = self.get_quiz(quiz_id)
        quiz_data = json.loads(quiz_json)
        questions = quiz_data.get("questions", [])

        if len(user_answers) != len(questions):
            raise gl.Rollback("Provided answer count does not match the quiz length.")

        score = 0
        total_questions = len(questions)

        for i in range(total_questions):
            correct_answer = questions[i]["answer"]
            if user_answers[i] == correct_answer:
                score += 1

        return json.dumps({
            "quiz_id": int(quiz_id),
            "score": score,
            "total": total_questions,
            "percentage": (score / total_questions) * 100 if total_questions > 0 else 0
        }, sort_keys=True)
